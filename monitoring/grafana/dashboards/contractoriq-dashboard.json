{
  "title": "ContractorIQ Overview",
  "uid": "contractoriq-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["contractoriq", "spring-boot", "kafka"],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "piechart",
      "title": "Contractors by recommendation tier",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (recommendation) (contractoriq_contractor_count{recommendation=~\"HIRE|CAUTION|AVOID\"})",
          "legendFormat": "{{recommendation}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "pieType": "donut",
        "displayLabels": ["name", "percent"]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Avg overall score (all contractors)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "avg(contractoriq_score_overall)",
          "legendFormat": "avg overall",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "API request rate (per route)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"contractoriq-api\"}[5m]))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "API p95 latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{application=\"contractoriq-api\"}[5m])))",
          "legendFormat": "{{uri}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Score recalculation events / hour",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kafka_consumer_records_consumed_total{topic=\"score-recalculation-events\"}[5m])) * 3600",
          "legendFormat": "events/hr",
          "refId": "A"
        },
        {
          "expr": "sum(kafka_consumer_fetch_manager_records_lag_max{topic=\"score-recalculation-events\"})",
          "legendFormat": "consumer lag",
          "refId": "B"
        }
      ]
    }
  ]
}
